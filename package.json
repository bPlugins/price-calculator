{
	"name": "price-calculator",
	"version": "1.0.0",
	"description": "Calculate price of products based on quantity.",
	"author": "Wasek Bellah",
	"license": "GPL-3.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"lint": "eslint src",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"format": "wp-scripts format",
		"start": "wp-scripts start --webpack-copy-php",
		"build": "wp-scripts build --webpack-copy-php",
		"i18n-pot": "wp i18n make-pot . languages/price-calculator.pot --exclude=\"src\" && cp ./languages/price-calculator.pot ./languages/price-calculator-en_US.po",
		"i18n-json": "wp i18n make-json languages/ --no-purge",
		"i18n-mo": "wp i18n make-mo languages/",
		"i18n": "npm run i18n-pot && npm run i18n-json && npm run i18n-mo",
		"plugin-zip": "wp-scripts plugin-zip",
		"zip": "zip -r price-calculator.zip build languages index.php plugin.php readme.txt",
		"bundle": "gulp clean && npm run lint && npm run build && npm run i18n && find . -name '.DS_Store' -delete && npm run zip"
	},
	"dependencies": {
		"immer": "^10.1.1",
		"react-router-dom": "^7.8.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@wordpress/blob": "^4.36.0",
		"@wordpress/block-editor": "^14.21.0",
		"@wordpress/blocks": "^13.10.0",
		"@wordpress/components": "^33.0.0",
		"@wordpress/compose": "^7.26.0",
		"@wordpress/data": "^10.26.0",
		"@wordpress/date": "^5.36.0",
		"@wordpress/i18n": "^5.26.0",
		"@wordpress/scripts": "^27.9.0",
		"@wp-playground/cli": "^3.1.18",
		"del": "^8.0.0",
		"dotenv": "^17.2.3",
		"eslint-webpack-plugin": "^4.2.0",
		"gulp": "^5.0.1",
		"gulp-freemius-deploy": "^1.0.11",
		"gulp-zip": "^6.1.0"
	}
}